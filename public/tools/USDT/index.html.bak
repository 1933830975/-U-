<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>USDT 地址管理器 | 霓虹终端</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            background: radial-gradient(circle at 20% 30%, #0a0f1a, #03060c);
            font-family: 'Share Tech Mono', 'Fira Code', monospace;
            min-height: 100vh;
            padding: 1.5rem;
            color: #0ff;
            position: relative;
        }
        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-image: linear-gradient(rgba(0,255,255,0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0,255,255,0.03) 1px, transparent 1px);
            background-size: 24px 24px;
            pointer-events: none;
            z-index: 0;
        }
        .container { max-width: 1300px; margin: 0 auto; position: relative; z-index: 2; backdrop-filter: blur(2px); }
        .header {
            border-bottom: 2px solid #0ff;
            padding-bottom: 1rem;
            margin-bottom: 2rem;
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .title { font-size: 2rem; font-weight: bold; letter-spacing: 2px; text-shadow: 0 0 6px #0ff; }
        .stats { font-size: 0.8rem; background: #0a0f1a; padding: 0.3rem 1rem; border: 1px solid #0ff; border-radius: 20px; }
        .card {
            background: rgba(8,16,24,0.75);
            backdrop-filter: blur(8px);
            border: 1px solid rgba(0,255,255,0.5);
            border-radius: 20px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: 0 0 18px rgba(0,255,255,0.1);
        }
        .address-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
        .address-table th { text-align: left; padding: 0.8rem 0.5rem; border-bottom: 2px solid #0ff; color: #9effff; text-transform: uppercase; }
        .address-table td { padding: 0.8rem 0.5rem; border-bottom: 1px solid rgba(0,255,255,0.2); font-family: monospace; word-break: break-all; }
        .address-table tr:hover { background: rgba(0,255,255,0.08); }
        .chain-badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 12px; font-size: 0.7rem; font-weight: bold; text-transform: uppercase; }
        .trc { background: #0a6; color: #000; border: 1px solid #0ff; }
        .erc { background: #a06; color: #fff; border: 1px solid #f0f; }
        .action-btn {
            background: rgba(0,20,30,0.9);
            border: 1.5px solid #0ff;
            color: #0ff;
            padding: 0.4rem 1rem;
            font-family: monospace;
            font-weight: bold;
            border-radius: 40px;
            cursor: pointer;
            transition: 0.2s;
            font-size: 0.8rem;
            margin: 0 0.2rem;
        }
        .action-btn:hover { background: #0ff; color: #000; box-shadow: 0 0 15px #0ff; }
        .delete-btn {
            background: none;
            border: 1px solid #ff3366;
            color: #ff3366;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            cursor: pointer;
            font-size: 0.7rem;
            transition: 0.2s;
        }
        .delete-btn:hover { background: #ff3366; color: #000; box-shadow: 0 0 8px #ff3366; }
        .add-area { display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem; }
        .add-input {
            flex: 3;
            background: #010a12;
            border: 1px solid #0ff;
            padding: 0.8rem 1rem;
            font-family: monospace;
            color: #0ff;
            border-radius: 12px;
            outline: none;
        }
        .add-input:focus { border-color: #ff00cc; box-shadow: 0 0 10px #ff00cc; }
        .summary { display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; margin-bottom: 1rem; }
        .summary-item {
            background: rgba(0,20,30,0.6);
            border-left: 4px solid #0ff;
            padding: 0.8rem 1.5rem;
            border-radius: 12px;
            flex: 1;
            min-width: 180px;
        }
        .summary-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; }
        .summary-value { font-size: 1.6rem; font-weight: bold; word-break: break-word; }
        .error-msg { background: rgba(255,30,80,0.2); border-left: 5px solid #ff3366; padding: 0.8rem; margin: 1rem 0; border-radius: 10px; color: #ff7b9c; }
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(5px);
            z-index: 1000;
            justify-content: